{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": false,
    "sourceMap": false,
    "types": ["node"]
  },
  "include": [
    "functions/**/*.ts",
    "layers/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "dist",
    ".aws-sam"
  ]
}
